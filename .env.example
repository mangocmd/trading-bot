# Anthropic
ANTHROPIC_API_KEY=

# Webhook auth (TradingView will send this as a shared secret in the payload)
WEBHOOK_SECRET=change-me

# Exchange mode: "mock" (default, no real orders) or "mexc" (live orders)
EXCHANGE_MODE=mock

# MEXC — only needed when EXCHANGE_MODE=mexc.
# Create a key with TRADE permission only. Do NOT enable withdrawals.
MEXC_API_KEY=
MEXC_API_SECRET=

# Risk guardrails
PORTFOLIO_VALUE_USD=1000
MAX_TRADE_SIZE_USD=50
MAX_TRADES_PER_DAY=3
